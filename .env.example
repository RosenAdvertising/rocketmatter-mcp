# rocketmatter-mcp — ProfitSolv LCS /v1 Integration API (scoped OAuth)
#
# Prefer `rocketmatter-mcp-setup`, which stores these in your OS keyring and runs
# the one-time OAuth consent. This file is the 0600 fallback when no keyring backend
# is available. NEVER commit real values.

# The integration's API key (sent as the X-Api-Key header).
ROCKETMATTER_API_KEY=your-lcs-app-api-key

# The OAuth app's client credentials (used for the code exchange + token refresh).
ROCKETMATTER_CLIENT_ID=ci-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ROCKETMATTER_CLIENT_SECRET=your-oauth-client-secret

# The redirect URI registered on the OAuth app (consent uses a manual code paste).
ROCKETMATTER_REDIRECT_URI=https://example.com/oauth/callback

# Optional host overrides:
#   ROCKETMATTER_BASE_URL      — OAuth host (consent + token). Rocket Matter:
#                                https://app.rocketmatter.net (default).
#                                CosmoLex: https://law.cosmolex.com
#   ROCKETMATTER_API_BASE_URL  — LCS /v1 data host (defaults to the ProfitSolv
#                                Azure host; override only for staging/sandbox).
# ROCKETMATTER_BASE_URL=https://app.rocketmatter.net
