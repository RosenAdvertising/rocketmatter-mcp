# Rocketmatter MCP — environment variables
# Copy to ~/.rocketmatter-mcp/.env and fill in your values.
# oauth_flow.py writes this file automatically during setup.

ROCKETMATTER_DOMAIN=https://app.rocketmatter.com
ROCKETMATTER_INSTALL=your_firm_install
ROCKETMATTER_USERNAME=you@yourfirm.com
ROCKETMATTER_PASSWORD=your_password_here
